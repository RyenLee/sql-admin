# SQL Admin 环境变量配置
# ========================
# 此文件仅用于 Web 模式（Axum 后端）
# 桌面模式（Tauri）不需要 .env，SQLite 路径由 Tauri 自动管理

# SQLite 数据库路径（Web 模式）
DATABASE_URL=sqlite:data/sql_admin.sqlite3?mode=rwc

# Web 服务监听地址
SERVER_ADDR=0.0.0.0:3000

# 运行环境
APP_ENV=dev
LOG_LEVEL=debug
LOG_DIR=

# Rust 日志级别
RUST_LOG=sql_admin=debug,axum=info

# 加密密钥（生产环境必须设置，开发环境可省略使用默认密钥）
# ENCRYPTION_KEY=your-32-byte-encryption-key-here!!

# ---- 开发脚本快速参考 ----
# Web 全栈:     .\scripts\dev.ps1 -Mode web
# 桌面应用:     .\scripts\dev.ps1 -Mode desktop
# 仅后端:       .\scripts\start-backend.ps1
# 仅前端:       .\scripts\start-frontend.ps1
# 桌面构建:     .\scripts\build-desktop.ps1